# did-cli configuration
# [REQ] DID instance URL (without protocol)
DID_URL=did.crayonconsulting.no

# [REQ] Session cookie value from browser (cookie name: "didapp")
DID_COOKIE=""

# [OPT] Debug output (0=off, 1=on)
debug=0

# [OPT] Default output format: json or pretty (default: json)
DID_DEFAULT_OUTPUT=json

# [OPT] Max display width for customer/project columns in pretty output (0 or unset = no limit)
DID_CUSTOMER_MAXLENGTH=
DID_PROJECT_MAXLENGTH=

# [OPT] Custom pretty format: JSON array of [column_name, display_name, width] tuples
# e.g. '[["customer.name","Customer",15],["project.name","Project",25],["duration","Hours",0]]'
DID_PRETTY_FORMAT=

# [AUTO] Cached on first use - clear to re-fetch
DID_USER_DISPLAY_NAME=
